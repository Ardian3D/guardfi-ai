# Deployed GuardFiReportRegistry address on HashKey Chain (from Phase 3 deploy).
# Required for "Save Proof On-Chain" and on-chain verification.
NEXT_PUBLIC_REGISTRY_ADDRESS=

# WalletConnect project id (injected wallets like MetaMask work without a real one).
# Get one at https://cloud.reown.com. Leave empty to use a dev placeholder.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: override the client-side HashKey Chain RPC used for read-only calls.
# If write/estimate calls 403, try https://hashkeychain-mainnet.alt.technology
NEXT_PUBLIC_HASHKEY_RPC_URL=https://mainnet.hsk.xyz

# Optional: server-side RPC used by the /api/scans scan engine.
HASHKEY_RPC_URL=https://mainnet.hsk.xyz

# DeepSeek AI report generation (server-side ONLY — never prefix with NEXT_PUBLIC).
# If unset, the app uses a deterministic fallback report and does not crash.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# HSP premium unlock.
# NEXT_PUBLIC_HSP_MODE=mock enables the mock adapter (dev/demo only).
# Any other value uses the real adapter skeleton (needs configuration).
NEXT_PUBLIC_HSP_MODE=mock
# Real HSP credentials (server-side ONLY — never NEXT_PUBLIC).
HSP_API_KEY=
HSP_API_BASE_URL=
# Safe, public pricing config.
NEXT_PUBLIC_PREMIUM_REPORT_PRICE=25
NEXT_PUBLIC_PREMIUM_REPORT_CURRENCY=HSP
