# Deployer wallet private key (NEVER commit the real value).
# Must hold HSK on HashKey Chain to pay for gas.
PRIVATE_KEY_DEPLOYER=

# HashKey Chain mainnet RPC endpoint.
# If write/estimate calls return 403, try the managed RPC:
#   https://hashkeychain-mainnet.alt.technology
HASHKEY_RPC_URL=https://mainnet.hsk.xyz

# Filled in AFTER deployment — the deployed GuardFiReportRegistry address.
# Consumed by the frontend (apps/web) to talk to the contract.
NEXT_PUBLIC_REGISTRY_ADDRESS=
